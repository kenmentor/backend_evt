const axios = require("axios");
const dotenv = require("dotenv");
dotenv.config();

/**
 * Paystack API base URL
 */
const PAYSTACK_BASE_URL = "https://api.paystack.co";

/**
 * Paystack secret key (from your .env)
 */
const PAYSTACK_SECRET = process.env.PAYSTACK_SECRET;

/**
 * Axios instance for Paystack
 */
const paystackApi = axios.create({
  baseURL: PAYSTACK_BASE_URL,
  headers: {
    Authorization: `Bearer ${PAYSTACK_SECRET}`,
    "Content-Type": "application/json",
  },
});

/**
 * ✅ Verify a payment using Paystack reference
 * @param {string} reference - The transaction reference to verify
 * @returns {Promise<{status: string, data: object}>}
 */
async function check_payment(reference) {
  try {
    if (!reference) throw new Error("Missing payment reference");

    const response = await paystackApi.get(`/transaction/verify/${reference}`);

    if (response.data.status && response.data.data.status === "success") {
      console.log("✅ Payment verified:", response.data.data.reference);
      return { status: "success", data: response.data.data };
    }

    return { status: "failed", data: response.data.data };
  } catch (err) {
    console.error(
      "❌ Payment verification failed:",
      err.response?.data || err.message
    );
    return { status: "error", message: err.message };
  }
}

/**
 * 💸 Refund a Paystack payment (full or partial)
 * @param {string} reference - The transaction reference to refund
 * @param {number} amount - Refund amount in naira (optional)
 * @returns {Promise<{status: string, data: object}>}
 */
async function refund(reference, amount) {
  try {
    if (!reference) throw new Error("Missing reference for refund");

    const refundData = {
      transaction: reference,
    };

    // Convert refund amount to kobo (Paystack uses kobo)
    if (amount) refundData.amount = amount * 100;

    const response = await paystackApi.post(`/refund`, refundData);

    if (response.data.status) {
      console.log(`💰 Refund successful for ${reference}`);
      return { status: "success", data: response.data.data };
    } else {
      console.log("⚠️ Refund failed:", response.data);
      return { status: "failed", data: response.data };
    }
  } catch (err) {
    console.error("❌ Refund failed:", err.response?.data || err.message);
    return { status: "error", message: err.message };
  }
}

/**
 * 🧠 Initialize a payment (for client-side checkout)
 * @param {object} options - email, amount, callback_url, metadata, etc.
 * @returns {Promise<{status: string, data: object}>}
 */
async function initialize_payment(options) {
  try {
    const response = await paystackApi.post(`/transaction/initialize`, options);
    if (response.data.status) {
      console.log("🚀 Payment initialized:", response.data.data.reference);
      return { status: "success", data: response.data.data };
    }
    return { status: "failed", data: response.data };
  } catch (err) {
    console.error(
      "❌ Failed to initialize payment:",
      err.response?.data || err.message
    );
    return { status: "error", message: err.message };
  }
}

module.exports = {
  check_payment,
  refund,
  initialize_payment,
};
